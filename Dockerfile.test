FROM python:3.14-slim
WORKDIR /app

# Install runtime deps + test tools
COPY requirements.txt requirements-test.txt /app/
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc build-essential curl && \
    python -m pip install --upgrade pip && \
    python -m pip install --no-cache-dir -r /app/requirements-test.txt

# Tests are NOT baked into the image; they are provided at runtime via the
# volume mount ./src:/app/src defined in docker-compose.test.yml. This means
# the live source is always used without requiring a rebuild.

WORKDIR /
CMD ["pytest", "-q", "/app/src/tests"]
